# =============================================
# Rift Batch Changes Platform — Environment Config
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================

# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-32chars-min
LOG_LEVEL=info

# MongoDB
MONGODB_URL=mongodb://rift:riftdev@localhost:27017/rift?authSource=admin
MONGODB_DATABASE=rift

# Redis
REDIS_URL=redis://localhost:6379/0

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=rift-main

# Auth (JWT)
JWT_SECRET=change-me-jwt-secret-32chars-minimum
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Bootstrap Super User (local dev only — change in production)
BOOTSTRAP_SUPERUSER_USERNAME=master
BOOTSTRAP_SUPERUSER_PASSWORD=master
BOOTSTRAP_SUPERUSER_DISPLAY_NAME=Rift Master

# KMS / Encryption (use real KMS in production)
KMS_KEY_REF=local-dev-key
KMS_PROVIDER=local

# SeaweedFS (S3-compatible Object Storage)
# S3 API: http://localhost:9000
# Filer UI: http://localhost:8888
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_BUCKET=rift-artifacts
OBJECT_STORE_ACCESS_KEY=minioadmin
OBJECT_STORE_SECRET_KEY=minioadmin
OBJECT_STORE_REGION=us-east-1

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_ENV=development
